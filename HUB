-- ── VALUE ROW (slider + textbox) ──────────────
local function makeValueRow(label,valueKey,minVal,maxVal,isFloat,order)
    return function(parent)
        local row=Instance.new("Frame")
        row.Name="Value_"..valueKey
        row.Size=UDim2.new(1,-scl(4),0,scl(56))
        row.BackgroundColor3=C.Row
        row.LayoutOrder=order
        row.Parent=parent
        corner(row,scl(9))
        uistroke(row,C.P1,1,0.82)

        -- entrance
        row.BackgroundTransparency=1
        local ox=row.Position.X.Offset
        row.Position=UDim2.new(row.Position.X.Scale,ox-scl(24),row.Position.Y.Scale,row.Position.Y.Offset)
        tweenPlay(row,0.38+order*0.05,{
            Position=UDim2.new(row.Position.X.Scale,ox,row.Position.Y.Scale,row.Position.Y.Offset),
            BackgroundTransparency=0,
        },Enum.EasingStyle.Quint)

        local lbl=Instance.new("TextLabel")
        lbl.Size=UDim2.new(0.52,0,0,scl(18))
        lbl.Position=UDim2.new(0,scl(10),0,scl(5))
        lbl.BackgroundTransparency=1
        lbl.Text=label
        lbl.Font=Enum.Font.GothamBold
        lbl.TextSize=scl(11)
        lbl.TextColor3=C.Text
        lbl.TextXAlignment=Enum.TextXAlignment.Left
        lbl.ZIndex=2
        lbl.Parent=row

        -- Textbox
        local tbF=Instance.new("Frame")
        tbF.Size=UDim2.new(0,scl(62),0,scl(24))
        tbF.Position=UDim2.new(1,-scl(72),0,scl(4))
        tbF.BackgroundColor3=C.InputBG
        tbF.BorderSizePixel=0
        tbF.ZIndex=3
        tbF.Parent=row
        corner(tbF,scl(6))
        local tbS=uistroke(tbF,C.P1,1,0.55)

        local tb=Instance.new("TextBox")
        tb.Size=UDim2.new(1,0,1,0)
        tb.BackgroundTransparency=1
        tb.Text=isFloat and string.format("%.2f",Values[valueKey]) or tostring(Values[valueKey])
        tb.Font=Enum.Font.GothamBold
        tb.TextSize=scl(11)
        tb.TextColor3=C.P3
        tb.ClearTextOnFocus=false
        tb.ZIndex=4
        tb.Parent=tbF

        tb.Focused:Connect(function()
            tweenPlay(tbS,0.15,{Color=C.P3,Transparency=0})
            tweenPlay(tbF,0.15,{BackgroundColor3=C.PanelLt})
        end)

        -- Slider
        local trackBg=Instance.new("Frame")
        trackBg.Size=UDim2.new(1,-scl(16),0,scl(5))
        trackBg.Position=UDim2.new(0,scl(8),0,scl(40))
        trackBg.BackgroundColor3=C.InputBG
        trackBg.BorderSizePixel=0
        trackBg.ZIndex=2
        trackBg.Parent=row
        corner(trackBg,scl(3))

        local initPct=math.clamp((Values[valueKey]-minVal)/(maxVal-minVal),0,1)

        local fill=Instance.new("Frame")
        fill.Size=UDim2.new(initPct,0,1,0)
        fill.BackgroundColor3=C.P1
        fill.BorderSizePixel=0
        fill.ZIndex=3
        fill.Parent=trackBg
        corner(fill,scl(3))
        local fG=Instance.new("UIGradient")
        fG.Color=ColorSequence.new({
            ColorSequenceKeypoint.new(0,Color3.fromRGB(90,40,200)),
            ColorSequenceKeypoint.new(0.5,Color3.fromRGB(150,80,255)),
            ColorSequenceKeypoint.new(1,Color3.fromRGB(210,155,255)),
        })
        fG.Parent=fill

        local thumb=Instance.new("Frame")
        thumb.Size=UDim2.new(0,scl(12),0,scl(12))
        thumb.AnchorPoint=Vector2.new(0.5,0.5)
        thumb.Position=UDim2.new(initPct,0,0.5,0)
        thumb.BackgroundColor3=C.White
        thumb.BorderSizePixel=0
        thumb.ZIndex=4
        thumb.Parent=trackBg
        corner(thumb,scl(6))
        uistroke(thumb,C.P2,1.5)

        local function syncFromVal()
            local v=Values[valueKey]
            local p=math.clamp((v-minVal)/(maxVal-minVal),0,1)
            fill.Size=UDim2.new(p,0,1,0)
            thumb.Position=UDim2.new(p,0,0.5,0)
            tb.Text=isFloat and string.format("%.2f",v) or tostring(v)
        end

        tb.FocusLost:Connect(function(enter)
            tweenPlay(tbS,0.2,{Color=C.P1,Transparency=0.55})
            tweenPlay(tbF,0.2,{BackgroundColor3=C.InputBG})
            if enter then
                local num=tonumber(tb.Text)
                if num then
                    num=math.clamp(num,minVal,maxVal)
                    if not isFloat then num=math.floor(num) end
                    Values[valueKey]=num
                    syncFromVal()
                    saveConfig()
                else
                    syncFromVal()
                end
            end
        end)

        local sliding=false
        local function updateFromSlider(ix)
            local p=math.clamp((ix-trackBg.AbsolutePosition.X)/trackBg.AbsoluteSize.X,0,1)
            local v=minVal+(maxVal-minVal)*p
            if not isFloat then v=math.floor(v) end
            v=math.clamp(v,minVal,maxVal)
            Values[valueKey]=v
            syncFromVal()
            saveConfig()
        end

        trackBg.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                sliding=true; updateFromSlider(i.Position.X)
                tweenPlay(thumb,0.1,{Size=UDim2.new(0,scl(15),0,scl(15))})
            end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if sliding and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
                updateFromSlider(i.Position.X)
            end
        end)
        UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                sliding=false
                tweenPlay(thumb,0.18,{Size=UDim2.new(0,scl(12),0,scl(12))},Enum.EasingStyle.Back,Enum.EasingDirection.Out)
            end
        end)
    end
end

