-- ── ANIMATED GRADIENT BORDER ──────────────────
-- Uses a Frame overlay with ClipsDescendants=false and a gradient UIStroke
-- The gradient is rotated every frame via RenderStepped
local gradRot   = 0
local gradItems = {}

local function makeGradBorder(frame, thickness, speed)
    speed = speed or 50
    local s = Instance.new("UIStroke")
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Thickness        = thickness or 2
    s.Transparency     = 0
    s.Parent           = frame

    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,    Color3.fromRGB(100, 40, 220)),
        ColorSequenceKeypoint.new(0.2,  Color3.fromRGB(160, 80, 255)),
        ColorSequenceKeypoint.new(0.45, Color3.fromRGB(220,160, 255)),
        ColorSequenceKeypoint.new(0.7,  Color3.fromRGB(140, 60, 255)),
        ColorSequenceKeypoint.new(1,    Color3.fromRGB(100, 40, 220)),
    })
    g.Parent = s
    table.insert(gradItems, {g=g, speed=speed, phase=#gradItems*73})
    return s, g
end

RunService.RenderStepped:Connect(function(dt)
    gradRot = gradRot + dt * 60
    for _,item in ipairs(gradItems) do
        if item.g and item.g.Parent then
            item.g.Rotation = (gradRot * (item.speed/60) + item.phase) % 360
        end
    end
end)

-- ── FLOATING PARTICLES ────────────────────────
local function spawnParticles(parent, count)
    for i=1,(count or 8) do
        local p=Instance.new("Frame")
        local sz=math.random(2,5)
        p.Size=UDim2.new(0,sz,0,sz)
        p.Position=UDim2.new(math.random(),0,math.random(),0)
        p.BackgroundColor3=i%2==0 and C.P2 or C.P3
        p.BackgroundTransparency=math.random(72,92)/100
        p.BorderSizePixel=0
        p.ZIndex=1
        corner(p,sz)
        p.Parent=parent
        local function drift()
            while p and p.Parent do
                local dur=math.random(28,72)/10
                local tx,ty=math.random(),math.random()
                tweenPlay(p, dur, {Position=UDim2.new(tx,0,ty,0)}, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                task.wait(dur)
            end
        end
        task.delay(math.random()*5, drift)
    end
end

