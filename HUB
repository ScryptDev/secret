-- ── AUTO STEAL ────────────────────────────────
_G.TaruAutoSteal = false
local stealHRP, stealHum = nil, nil

local function refreshSteal(char)
    stealHRP = char:WaitForChild("HumanoidRootPart",5)
    stealHum = char:WaitForChild("Humanoid",5)
end
LocalPlayer.CharacterAdded:Connect(refreshSteal)
if LocalPlayer.Character then refreshSteal(LocalPlayer.Character) end

local function getPromptPos(p)
    local par = p.Parent
    if par:IsA("BasePart")   then return par.Position end
    if par:IsA("Model")      then
        local pp = par.PrimaryPart or par:FindFirstChildWhichIsA("BasePart")
        if pp then return pp.Position end
    end
    if par:IsA("Attachment") then return par.WorldPosition end
    local pt = par:FindFirstChildWhichIsA("BasePart",true)
    return pt and pt.Position or nil
end

local function findSteal()
    if not stealHRP then return nil, math.huge end
    local best, bd = nil, math.huge
    local f = workspace:FindFirstChild("Plots")
    if not f then return nil, math.huge end
    for _,d in pairs(f:GetDescendants()) do
        if d:IsA("ProximityPrompt") and d.Enabled and d.ActionText=="Steal" then
            local pos = getPromptPos(d)
            if pos then
                local dist = (stealHRP.Position-pos).Magnitude
                if dist<=d.MaxActivationDistance and dist<bd then bd=dist; best=d end
            end
        end
    end
    return best, bd
end

local function fireSteal(p)
    if not p or not p:IsDescendantOf(workspace) then return end
    pcall(function() fireproximityprompt(p,1000,math.huge) end)
    pcall(function() p:InputHoldBegin(); task.wait(0.03); p:InputHoldEnd() end)
end

local sPrompt, sDist, sLastScan = nil, math.huge, 0
RunService.Heartbeat:Connect(function()
    if not _G.TaruAutoSteal then return end
    local now = tick()
    if now-sLastScan>=Values.AutoStealScanRate then
        sPrompt, sDist = findSteal(); sLastScan=now
    end
end)
task.spawn(function()
    while true do
        task.wait(Values.AutoStealFireRate)
        if _G.TaruAutoSteal and stealHum and stealHum.WalkSpeed>25 then
            if sPrompt and sDist<=sPrompt.MaxActivationDistance then
                fireSteal(sPrompt); task.wait(Values.AutoStealCooldown)
            end
        end
    end
end)

-- ── SENTRY DESTROY ────────────────────────────
local sentryActive, sentryThread = false, nil

local function teleportSentries()
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    for _,pl in ipairs(Players:GetPlayers()) do
        if pl~=LocalPlayer then
            local sn = "Sentry_"..tostring(pl.UserId)
            local sv = workspace:FindFirstChild(sn)
            if not sv then
                local t = ReplicatedStorage:FindFirstChild(sn)
                if t then sv=t:Clone(); sv.Parent=workspace end
            end
            if sv then
                sv.CFrame=CFrame.new(hrp.Position+hrp.CFrame.LookVector*3+Vector3.new(0,2,0))
                sv.CanCollide=true
            end
        end
    end
end

local function EnableSentryDestroy()
    if sentryThread then return end
    sentryActive=true
    sentryThread=task.spawn(function()
        while sentryActive do teleportSentries(); task.wait(Values.SentryLoopRate) end
    end)
end

local function DisableSentryDestroy()
    sentryActive=false; sentryThread=nil
end

