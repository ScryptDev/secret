local CONFIG_FILE = "TARU_HUB_Config.json"

local function saveConfig()
    pcall(function()
        writefile(CONFIG_FILE, HttpService:JSONEncode({Values=Values, Enabled=Enabled}))
    end)
end

local function loadConfig()
    pcall(function()
        if isfile(CONFIG_FILE) then
            local d = HttpService:JSONDecode(readfile(CONFIG_FILE))
            if d.Values  then for k,v in pairs(d.Values)  do if Values[k]  ~=nil then Values[k]  =v end end end
            if d.Enabled then for k,v in pairs(d.Enabled) do if Enabled[k] ~=nil then Enabled[k] =v end end end
        end
    end)
end
