        local ks=uistroke(knob,isOn and C.P2 or Color3.fromRGB(70,60,100),1.5)

        -- Hitbox
        local hb=Instance.new("TextButton")
        hb.Size=UDim2.new(1,0,1,0)
        hb.BackgroundTransparency=1
        hb.Text=""
        hb.ZIndex=4
        hb.Parent=row

        hb.MouseEnter:Connect(function()
            if not Enabled[featureKey] then
                tweenPlay(row,0.14,{BackgroundColor3=C.RowHover})
                tweenPlay(rs,0.14,{Transparency=0.5})
            end
        end)
        hb.MouseLeave:Connect(function()
            if not Enabled[featureKey] then
                tweenPlay(row,0.14,{BackgroundColor3=C.Row})
                tweenPlay(rs,0.14,{Transparency=0.82})
            end
        end)

        local function setState(on)
            Enabled[featureKey]=on
            applyFeature(featureKey,on)

            -- track
            tweenPlay(track,0.3,{BackgroundColor3=on and C.ToggleOn or C.ToggleOff},Enum.EasingStyle.Quint)
            tGrad.Enabled=on

            -- knob: slide + squish + snap back
            tweenPlay(knob,0.32,{Position=on and UDim2.new(0,scl(24),0.5,-scl(8)) or UDim2.new(0,scl(3),0.5,-scl(8))},Enum.EasingStyle.Quint)
            tweenPlay(knob,0.08,{Size=UDim2.new(0,scl(20),0,scl(14))},Enum.EasingStyle.Quad)
            task.delay(0.09,function()
                tweenPlay(knob,0.24,{Size=UDim2.new(0,scl(17),0,scl(17))},Enum.EasingStyle.Back,Enum.EasingDirection.Out)
            end)
            tweenPlay(ks,0.2,{Color=on and C.P2 or Color3.fromRGB(70,60,100)})

            -- dot ring
            tweenPlay(dotRing,0.24,{BackgroundColor3=on and C.Green or C.Red})
            tweenPlay(dot,0.24,{BackgroundColor3=on and C.Green or C.Red})

            -- stripe, row, stroke
            tweenPlay(stripe,0.24,{BackgroundColor3=on and C.P2 or C.ToggleOff})
            tweenPlay(row,0.24,{BackgroundColor3=on and C.RowActive or C.Row})
            tweenPlay(rs,0.24,{Color=on and C.P2 or C.P1, Transparency=on and 0.1 or 0.82})
            tweenPlay(lbl,0.2,{TextColor3=on and C.Text or C.TextDim})
        end

        hb.Activated:Connect(function() setState(not Enabled[featureKey]) end)
    end
end

