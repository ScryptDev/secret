-- // [4] UTILITY FUNCTIONS //
local function getHRP()
    local char = LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso")
end

local function getHumanoid()
    local char = LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChild("Humanoid")
end

local function createToggle(parent, text, key, yOffset)
    local toggleFrame = Instance.new("Frame")
    toggleFrame.Name = key .. "_Toggle"
    toggleFrame.Size = UDim2.new(1, -16, 0, 28)
    toggleFrame.Position = UDim2.new(0, 8, 0, yOffset)
    toggleFrame.BackgroundColor3 = CONFIG.Colors.ToggleOff
    toggleFrame.Parent = parent

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 5)
    corner.Parent = toggleFrame

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.65, 0, 1, 0)
    label.Position = UDim2.new(0, 8, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = CONFIG.Colors.Text
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.GothamBold
    label.TextSize = 10
    label.Parent = toggleFrame

    local switch = Instance.new("Frame")
    switch.Size = UDim2.new(0, 32, 0, 15)
    switch.Position = UDim2.new(1, -40, 0.5, -7)
    switch.AnchorPoint = Vector2.new(1, 0.5)
    switch.BackgroundColor3 = CONFIG.Colors.ToggleOff
    switch.Parent = toggleFrame

    local switchCorner = Instance.new("UICorner")
    switchCorner.CornerRadius = UDim.new(1, 0)
    switchCorner.Parent = switch

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 11, 0, 11)
    knob.Position = UDim2.new(0, 2, 0.5, -5)
    knob.AnchorPoint = Vector2.new(0, 0.5)
    knob.BackgroundColor3 = Color3.fromRGB(110, 55, 200)
    knob.Parent = switch

    local knobCorner = Instance.new("UICorner")
    knobCorner.CornerRadius = UDim.new(1, 0)
    knobCorner.Parent = knob

    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 1, 0)
    button.BackgroundTransparency = 1
    button.Text = ""
    button.Parent = switch

    ToggleSwitches[key] = {Frame = switch, Knob = knob, State = false}

    return button
end

