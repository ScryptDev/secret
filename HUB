-- ── WALLHACK ──────────────────────────────────
local whOrig = {}
local whDescConn, whCharConn = nil, nil

local function isBase(obj)
    if not (obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("UnionOperation")) then return false end
    local n = obj.Name:lower()
    local p = obj.Parent and obj.Parent.Name:lower() or ""
    return (n:find("base") or n:find("claim") or p:find("base") or p:find("claim")) and true or false
end

local function whAlpha() return math.clamp(Values.WallhackTransparency/10, 0.01, 0.99) end

local function applyWH(obj)
    if not whOrig[obj] then whOrig[obj]=obj.LocalTransparencyModifier end
    obj.LocalTransparencyModifier=whAlpha()
end

local function applyWHAll()
    for _,obj in ipairs(workspace:GetDescendants()) do if isBase(obj) then applyWH(obj) end end
end

local function restoreWH()
    for obj,orig in pairs(whOrig) do pcall(function() obj.LocalTransparencyModifier=orig end) end
    whOrig={}
end

local function EnableWallhack()
    applyWHAll()
    whDescConn=workspace.DescendantAdded:Connect(function(obj) if isBase(obj) then applyWH(obj) end end)
    whCharConn=LocalPlayer.CharacterAdded:Connect(function() task.wait(0.5); applyWHAll() end)
end

local function DisableWallhack()
    if whDescConn then whDescConn:Disconnect(); whDescConn=nil end
    if whCharConn then whCharConn:Disconnect(); whCharConn=nil end
    restoreWH()
end

RunService.Heartbeat:Connect(function()
    if not Enabled.Wallhack then return end
    local t = whAlpha()
    for obj in pairs(whOrig) do pcall(function() obj.LocalTransparencyModifier=t end) end
end)

-- ── DUAL AIM BOT ──────────────────────────────
local dualAimLaserConn = nil
local dualAimWebConn   = nil

local function dualGetNearest()
    local c = LocalPlayer.Character
    if not c then return nil end
    local myHRP = c:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end
    local nearest, shortest = nil, Values.DualAimRange
    for _,pl in ipairs(Players:GetPlayers()) do
        if pl~=LocalPlayer and pl.Character then
            local hrp = pl.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (hrp.Position-myHRP.Position).Magnitude
                if dist<shortest then shortest=dist; nearest=pl end
            end
        end
    end
    return nearest
end

local function dualHasTool(name)
    local bp = LocalPlayer.Backpack
    local ch = LocalPlayer.Character
    return (bp and bp:FindFirstChild(name)) or (ch and ch:FindFirstChild(name))
end

local function dualEquipOnly(name)
    local ch = LocalPlayer.Character
    local bp = LocalPlayer.Backpack
    if not ch or not bp then return false end
    local hum = ch:FindFirstChildOfClass("Humanoid")
    if hum then
        for _,t in ipairs(ch:GetChildren()) do
            if t:IsA("Tool") and t.Name~=name then t.Parent=bp end
        end
    end
    local tool = bp:FindFirstChild(name) or ch:FindFirstChild(name)
    if tool and tool.Parent==bp then tool.Parent=ch; return true end
    return tool~=nil
end

local Event = nil
pcall(function()
    Event = ReplicatedStorage:WaitForChild("Packages",3):WaitForChild("Net",3):WaitForChild("RE/UseItem",3)
end)

local function useLaserCape(targetPart)
    if not targetPart or not Event then return end
    pcall(function() Event:FireServer(targetPart.Position, targetPart) end)
end

local function useWebSlinger(targetPart)
    if not targetPart or not Event then return end
    local ch = LocalPlayer.Character
    if not ch then return end
    local tool = LocalPlayer.Backpack:FindFirstChild("Web Slinger") or ch:FindFirstChild("Web Slinger")
    if tool and tool:FindFirstChild("Handle") then
        local handle = tool.Handle
        pcall(function() Event:FireServer(targetPart.Position, targetPart, handle) end)
    end
end

local function setupLaserAim()
    local ch = LocalPlayer.Character
    local bp = LocalPlayer.Backpack
    local laserTool = (bp and bp:FindFirstChild("Laser Cape")) or (ch and ch:FindFirstChild("Laser Cape"))
    if not laserTool then return end
    if dualAimLaserConn then dualAimLaserConn:Disconnect() end
    dualAimLaserConn = laserTool.Activated:Connect(function()
        local target = dualGetNearest()
        if target and target.Character then
            local hrp = target.Character:FindFirstChild("HumanoidRootPart")
            if hrp then useLaserCape(hrp) end
        end
    end)
end

local function setupWebAim()
    local ch = LocalPlayer.Character
    local bp = LocalPlayer.Backpack
    if not (bp and bp:FindFirstChild("Web Slinger")) and not (ch and ch:FindFirstChild("Web Slinger")) then
        pcall(function()
            local rf = ReplicatedStorage:WaitForChild("Packages",3):WaitForChild("Net",3):WaitForChild("RF/CoinsShopService/RequestBuy",3)
            rf:InvokeServer("Web Slinger")
        end)
        task.wait(1)
    end
    local webTool = (bp and bp:FindFirstChild("Web Slinger")) or (ch and ch:FindFirstChild("Web Slinger"))
    if not webTool then return end
    if dualAimWebConn then dualAimWebConn:Disconnect() end
    dualAimWebConn = webTool.Activated:Connect(function()
        local target = dualGetNearest()
        if target and target.Character then
            local hrp = target.Character:FindFirstChild("HumanoidRootPart")
            if hrp then useWebSlinger(hrp) end
        end
    end)
end

local function EnableDualAimBot()
    setupLaserAim()
    setupWebAim()
    LocalPlayer.CharacterAdded:Connect(function()
        if Enabled.DualAimBot then task.wait(2); setupLaserAim(); setupWebAim() end
    end)
end

local function DisableDualAimBot()
    if dualAimLaserConn then dualAimLaserConn:Disconnect(); dualAimLaserConn=nil end
    if dualAimWebConn   then dualAimWebConn:Disconnect();   dualAimWebConn=nil   end
end

-- ── INVISIBLE COMBO (one-shot button) ─────────
local isComboRunning = false

local function RunInvisibleCombo()
    if isComboRunning then return end
    isComboRunning = true
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        local bp = LocalPlayer:WaitForChild("Backpack")
        local cloak = bp:FindFirstChild("Invisibility Cloak")
        if not cloak then return end
        hum:UnequipTools()
        task.wait(0.05)
        hum:EquipTool(cloak)
        task.wait(0.05)
        cloak:Activate()
        task.wait(1)
