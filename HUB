        if not qc then return end
        hum:EquipTool(qc)
        task.wait(0.05)
        qc:Activate()
    end)
    task.wait(0.3)
    isComboRunning = false
end

-- ── INSTANT CLONER (toggle + keybind) ─────────
local clonerActive   = false
local clonerConn     = nil
local clonerKeybindConn = nil

local function runInstantCloner()
    if not Enabled.InstantCloner then return end
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        for _,t in ipairs(char:GetChildren()) do
            if t:IsA("Tool") then hum:UnequipTools(); task.wait(0.1); break end
        end
        local bp = LocalPlayer.Backpack
        local cloner = bp:FindFirstChild("Quantum Cloner")
        if not cloner then return end
        hum:EquipTool(cloner)
        task.wait()
        local useRemote = ReplicatedStorage:WaitForChild("Packages",3):WaitForChild("Net",3):WaitForChild("RE/UseItem",3)
        useRemote:FireServer()
        task.wait()
        local clonerRemote = ReplicatedStorage:WaitForChild("Packages",3):WaitForChild("Net",3):WaitForChild("RE/QuantumCloner/OnTeleport",3)
        clonerRemote:FireServer()
    end)
end

local function EnableInstantCloner()
    -- keybind listener
    clonerKeybindConn = UserInputService.InputBegan:Connect(function(inp, gpe)
        if gpe then return end
        local kb = Values.ClonerKeybind
        if inp.KeyCode == Enum.KeyCode[kb] then
            runInstantCloner()
        end
    end)
end

local function DisableInstantCloner()
    if clonerKeybindConn then clonerKeybindConn:Disconnect(); clonerKeybindConn=nil end
end

-- ── DISPATCHER ────────────────────────────────
local function applyFeature(name, state)
    if     name=="AntiRagdoll"   then if state then EnableAntiRagdoll()   else DisableAntiRagdoll()   end
    elseif name=="InfinityJump"  then if state then EnableInfinityJump()  else DisableInfinityJump()  end
    elseif name=="AutoSteal"     then _G.TaruAutoSteal=state
    elseif name=="SentryDestroy" then if state then EnableSentryDestroy() else DisableSentryDestroy() end
    elseif name=="TigyBooster"   then if state then EnableTigyBooster()   else DisableTigyBooster()   end
    elseif name=="Wallhack"      then if state then EnableWallhack()      else DisableWallhack()      end
    elseif name=="DualAimBot"    then if state then EnableDualAimBot()    else DisableDualAimBot()    end
    elseif name=="InstantCloner" then if state then EnableInstantCloner() else DisableInstantCloner() end
    end
    saveConfig()
end

for name, state in pairs(Enabled) do
    if state then applyFeature(name, true) end
end

