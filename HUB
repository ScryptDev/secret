local function setTabStyle(name)
    for tName,btn in pairs(tabButtons) do
        if tName==name then
            tweenPlay(btn,0.22,{BackgroundColor3=C.PanelLt,TextColor3=C.P4})
            -- slide indicator to this button's X position
            local bx=btn.AbsolutePosition.X-TabBar.AbsolutePosition.X
            tweenPlay(tabIndicator,0.28,{
                Position=UDim2.new(0,bx+scl(8),1,-scl(2)),
                Size=UDim2.new(0,btn.AbsoluteSize.X-scl(16),0,scl(2))
            },Enum.EasingStyle.Back)
        else
            tweenPlay(btn,0.22,{BackgroundColor3=C.Row,TextColor3=C.TextDim})
        end
    end
end

local function openTab(name)
    if activeTab==name then
        activeTab=nil; tabOpen=false
        -- reset indicator
        tweenPlay(tabIndicator,0.2,{Size=UDim2.new(0,0,0,scl(2))})
        for _,btn in pairs(tabButtons) do
            tweenPlay(btn,0.2,{BackgroundColor3=C.Row,TextColor3=C.TextDim})
        end
        slideOut(function() animMain() end)
        return
    end
    local switching=(activeTab~=nil and tabOpen)
    activeTab=name; tabOpen=true
    setTabStyle(name)
    if switching then
        slideOut(function() buildTab(name); slideIn() end)
    else
        buildTab(name); slideIn(); animMain()
    end
end

